# ─── Square Payment Configuration ─────────────────────────────────────────
# Get your credentials from https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key_here
# Square Environment: sandbox for testing, production for live
SQUARE_ENVIRONMENT=sandbox

# ─── OpenAI Configuration ───────────────────────────────────────────────────
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-organization-id-here

# ─── NVIDIA AI Configuration (NIM) ──────────────────────────────────────────
# Get your API key from https://console.nvidia.com/
# Base URL: https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=qwen/qwen3-next-80b-a3b-instruct

# ─── Anthropic (Claude) Configuration ──────────────────────────────────────
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ─── Hermes AI Agent Configuration ─────────────────────────────────────────
# Master AI orchestrator that coordinates all AI providers
# NVIDIA PRIMARY - Uses free NVIDIA NIM models first, autonomous fallback between models
# OpenAI/Anthropic are secondary fallbacks used only when NVIDIA fails
HERMES_ENABLED=true
HERMES_DEFAULT_PROVIDER=nvidia  # PRIMARY: All free NVIDIA models
HERMES_FALLBACK_PROVIDER=openai  # SECONDARY: Paid fallback when NVIDIA unavailable
HERMES_TERTIARY_PROVIDER=anthropic  # TERTIARY: Final fallback for complex reasoning
HERMES_BLAND_DELEGATION_ENABLED=true
HERMES_MAX_CONCURRENT_AGENTS=3

# ─── Bland AI Configuration ─────────────────────────────────────────────────
# Get your API key from https://bland.ai/api-settings
BLAND_AI_API_KEY=your_bland_api_key_here
BLAND_AI_WEBHOOK_SECRET=your_webhook_secret_here
BLAND_WEBHOOK_URL=https://your-domain.com/api/ai/bland/webhook

# Outbound calling defaults
BLAND_DEFAULT_FROM_NUMBER=+1XXXXXXXXXX
BLAND_DEFAULT_CALLER_ID=+1XXXXXXXXXX
BLAND_DEFAULT_VOICE=30972a71-c4b5-4aa3-9ce7-e065d6409a8f
BLAND_DEFAULT_LANGUAGE=en
BLAND_MAX_CALL_DURATION=600

# Autonomous calling features
BLAND_AUTONOMOUS_ENABLED=true
BLAND_VOICEMAIL_DETECTION=true
BLAND_SENTIMENT_ANALYSIS=true
BLAND_TRANSCRIPTION_ENABLED=true

# ─── Stripe (Legacy - switching to Square) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Resend (Email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
SMTP_USER=your_smtp_user@outlook.com
SMTP_PASS=your_smtp_password

# ─── Legal Services AI ──────────────────────────────────────────────────────
# Premium legal-specific AI configuration
LEGAL_SERVICES_ENABLED=true
LEGAL_PRIVILEGE_MODE=true
LEGAL_HIPAA_MODE=true

# ─── Auto-upgrade thresholds ────────────────────────────────────────────────
AUTO_UPGRADE_STARTER_TO_GROWTH=3000
AUTO_UPGRADE_GROWTH_TO_PRO=10000

# ─── Call Summary Email ─────────────────────────────────────────────────────
CALL_SUMMARY_EMAIL=admin@example.com
ADMIN_EMAIL=admin@example.com

# ─── Inbound AI Answering ───────────────────────────────────────────────────
INBOUND_PHONE_NUMBER=+1XXXXXXXXXX
INBOUND_TRANSFER_NUMBER=+1XXXXXXXXXX
INBOUND_GREETING=Hello, you have reached GlobalVoice AI. I am your virtual receptionist. How can I help you today?
BUSINESS_HOURS_ENABLED=true
BUSINESS_HOURS_MONDAY=09:00-17:00
BUSINESS_HOURS_TUESDAY=09:00-17:00
BUSINESS_HOURS_WEDNESDAY=09:00-17:00
BUSINESS_HOURS_THURSDAY=09:00-17:00
BUSINESS_HOURS_FRIDAY=09:00-17:00
BUSINESS_HOURS_SATURDAY=closed
BUSINESS_HOURS_SUNDAY=closed
AFTER_HOURS_BEHAVIOR=voicemail
VOICEMAIL_EMAIL=frontdeskllc@outlook.com