# =============================================================================
# FrontDesk Agents OS — UNIFIED environment (single business)
# Receptionist platform + Website builder, consolidated into one app.
# Copy to .env and fill real values. Masked placeholders only — never commit secrets.
# =============================================================================

# ---- Owner / auth -----------------------------------------------------------
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change_me                 # admin console login (fails closed if unset)
PASSWORD_SALT=random_long_string         # customer/owner password hashing salt
SECRETS_ENCRYPTION_KEY=random_32b_hex    # AES-256 for in-app secret overrides (else Blob token)
CUSTOMER_SESSION_SECRET=random_long_string

# ---- Storage / data ---------------------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx # durable JSON store (bookings, leads, configs…)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io   # website-builder cache / queues
UPSTASH_REDIS_REST_TOKEN=xxx

# ---- LLM brains (HERMES cascade) -------------------------------------------
NIM_API_KEY=nvapi-xxx                    # primary brain (NVIDIA NIM)
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.3-70b-instruct
NIM_MAX_TOKENS=1024
ANTHROPIC_API_KEY=sk-ant-xxx             # Claude (fallback + website generation)
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=sk-xxx                    # last-resort fallback
OPENAI_MODEL=gpt-4o-mini
ZAI_API_KEY=xxx                          # website-builder generation provider

# ---- Voice (Bland) ----------------------------------------------------------
BLAND_API_KEY=org_xxx
BLAND_INBOUND_NUMBER=+1XXXXXXXXXX
BLAND_OUTBOUND_NUMBER=+1XXXXXXXXXX
BLAND_CALLER_ID=+1XXXXXXXXXX
BLAND_FROM_NUMBER=+1XXXXXXXXXX
BLAND_AGENT_NAME=Ava
BLAND_AGENT_LAST_NAME=Sterling
BLAND_DEFAULT_LANGUAGE=babel
BLAND_LANG_DETECT_PERIOD=4
BLAND_WEBHOOK_URL=https://www.frontdeskagents.com/api/bland/webhook
BLAND_WEBHOOK_SECRET=random_long_string

# ---- SMS (Twilio — missed-call recovery, confirmations) --------------------
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM=+1XXXXXXXXXX

# ---- Image generation (website builder) ------------------------------------
IMAGE_PROVIDER=fal                       # fal | higgsfield | custom
IMAGE_API_KEY=xxx
IMAGE_API_URL=https://...
FAL_API_KEY=xxx
FAL_IMAGE_URL=https://fal.run/...
HIGGSFIELD_KEY_ID=xxx
HIGGSFIELD_KEY_SECRET=xxx

# ---- Prospecting (lead generation) -----------------------------------------
GOOGLE_PLACES_API_KEY=xxx                # business discovery for the acquisition engine

# ---- Payments ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_xxx            # server-side Stripe (checkout, subscriptions)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_EARLYBIRD_COUPON_ID=xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
SQUARE_ACCESS_TOKEN=xxx                  # optional alt processor
PAYPAL_CLIENT_ID=xxx                     # optional alt processor
PAYPAL_CLIENT_SECRET=xxx
CASHAPP_CASHTAG=$yourtag                 # manual payment handles (website-builder)
ZELLE_HANDLE=owner@example.com

# ---- Email ------------------------------------------------------------------
SMTP_HOST=smtp-mail.outlook.com          # primary transport (reaches any recipient)
SMTP_PORT=587
SMTP_USER=owner@outlook.com
SMTP_PASS=xxx
RESEND_API_KEY=re_xxx                    # fallback transport
RESEND_FROM=FrontDesk Agents <noreply@frontdeskagents.com>
EMAIL_FROM=FrontDesk Agents <noreply@frontdeskagents.com>
NOTIFY_EMAIL=owner@example.com           # owner alerts (bookings, leads, daily report)
SALES_EMAIL=sales@example.com
OUTREACH_FROM=outreach@example.com       # website-builder cold outreach sender

# ---- Notifications (Telegram) ----------------------------------------------
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_OWNER_CHAT=xxx

# ---- Automation -------------------------------------------------------------
CRON_SECRET=random_long_string           # gates /api/cron/* (Vercel Cron bearer)
