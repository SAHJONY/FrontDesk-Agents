[TEMPLATE]
# =============================================================================
# FRONTDESK AGENTS — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these in your hosting provider (Vercel, etc.)
# =============================================================================

# ── Application ────────────────────────────────────

NEXT_PUBLIC_APP_URL="http://localhost:3000"
# REQUIRED. The public URL of your application.

NEXT_PUBLIC_GA_ID=""
# OPTIONAL. Google Analytics 4 measurement ID (e.g., G-XXXXXXXXXX).

# ── Supabase ───────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=""
# REQUIRED. Your Supabase project URL.
# Found in: Supabase Dashboard > Settings > API > Project URL

NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# REQUIRED. Supabase anonymous/public API key.

SUPABASE_SERVICE_ROLE_KEY=""
# REQUIRED for admin operations. Supabase service_role key.
# WARNING: Never expose this to the client. Server-side only.

# ── Stripe ─────────────────────────────────────────

STRIPE_SECRET_KEY=""
# REQUIRED for payments. Stripe secret API key.
# Test: sk_test_... | Live: sk_live_...

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# NOT YET IN USE — Reserved for future Stripe frontend integration.

STRIPE_WEBHOOK_SECRET=""
# REQUIRED for webhooks. Stripe webhook signing secret (whsec_...).

# ── Square ─────────────────────────────────────────

SQUARE_ACCESS_TOKEN=""
# REQUIRED for Square payments. Square OAuth access token.

SQUARE_ENVIRONMENT="sandbox"
# Options: sandbox | production

SQUARE_WEBHOOK_SIGNATURE_KEY=""
# REQUIRED for Square webhooks. Square webhook signature key.

SQUARE_WEBHOOK_URL=""
# OPTIONAL. Square webhook notification URL.

# ── Twilio ─────────────────────────────────────────

TWILIO_ACCOUNT_SID=""
# REQUIRED for phone/SMS. Twilio Account SID.

TWILIO_AUTH_TOKEN=""
# REQUIRED for phone/SMS. Twilio Auth Token.

TWILIO_PHONE_NUMBER=""
# REQUIRED for phone/SMS. Twilio phone number in E.164 format.

# ── Bland AI ───────────────────────────────────────

BLANDAI_API_KEY=""
# REQUIRED for AI phone calls. Bland AI API key.

BLANDAI_CALLER_ID=""
# OPTIONAL. Bland AI caller ID for outbound calls.

BLANDAI_SALES_PHONE_NUMBER=""
# OPTIONAL. Bland AI sales/prospecting phone number.

# ── LiveKit ────────────────────────────────────────

LIVEKIT_API_KEY=""
# REQUIRED for real-time voice/video. LiveKit API key.

LIVEKIT_API_SECRET=""
# REQUIRED for real-time voice/video. LiveKit API secret.

LIVEKIT_WS_URL="wss://your-project.livekit.cloud"
# REQUIRED. LiveKit WebSocket URL.

# ── AI Services ────────────────────────────────────

OPENAI_API_KEY=""
# REQUIRED for AI features. OpenAI API key.

NVIDIA_NIM_API_KEY=""
# REQUIRED for NVIDIA NIM AI models. Get your key from https://ngc.nvidia.com/setup/api-key

# ── Owner Dashboard ────────────────────────────────

OWNER_EMAIL="admin@yourbusiness.com"
# REQUIRED. Owner/admin login email.

OWNER_PASSWORD_HASH=""
# REQUIRED. bcrypt hash of (password + PASSWORD_SALT).
# Generate: node -e "const b=require('bcryptjs'); console.log(b.hashSync('YOUR_PASSWORD' + process.env.PASSWORD_SALT, 12))"
# Set PASSWORD_SALT first, then generate the hash and set it here.

PASSWORD_SALT=""
# REQUIRED. Salt for bcrypt password hashing. Must be set in ALL environments (dev, staging, production).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Vercel (Auto-Injected) ────────────────────────

VERCEL_OIDC_TOKEN=""
# Vercel Auto-Injected — DO NOT SET MANUALLY.

NODE_ENV="development"
# Next.js manages this automatically during builds and runtime.

# ═══════════════════════════════════════════════════════════════════════
# DEPLOYMENT CHEATSHEET
# ═══════════════════════════════════════════════════════════════════════
#
# Step 1: Set up Supabase
#   - Create project at https://supabase.com
#   - Run migrations
#
# Step 2: Configure payments (Stripe, Square)
#
# Step 3: Set up phone services (Twilio, Bland AI)
#
# Step 4: Set up LiveKit for real-time voice
#
# Step 5: Set owner credentials
#   a) Generate PASSWORD_SALT: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   b) Set PASSWORD_SALT in your env
#   c) Generate OWNER_PASSWORD_HASH: node -e "const b=require('bcryptjs'); console.log(b.hashSync('YOUR_PASSWORD' + process.env.PASSWORD_SALT, 12))"
#   d) Set the resulting hash as OWNER_PASSWORD_HASH
#   e) Save your password — there is no recovery without it
#
# Step 6: Deploy to Vercel with all env vars
# ═══════════════════════════════════════════════════════════════════════
