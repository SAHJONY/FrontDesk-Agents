# ==========================================
# FRONTDESK AGENTS - Environment Variables
# Copy this to .env.local and fill in your values
# ==========================================

# ==========================================
# SUPABASE - Database & Authentication
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# TWILIO - Voice & SMS Communications
# Get these from: https://console.twilio.com/
# ==========================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# BLAND.AI - AI-Powered Outbound Calls
# Get from: https://www.bland.ai/
# ==========================================
BLAND_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# OPENAI - GPT Language Processing
# Get from: https://platform.openai.com/api-keys
# ==========================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# DATABASE - PostgreSQL Connection
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/frontdesk

# ==========================================
# SECURITY - Encryption & Sessions
# Generate secure random strings (32+ characters)
# ==========================================
ENCRYPTION_KEY=your-32-character-minimum-encryption-key-here
SESSION_SECRET=your-32-character-minimum-session-secret-here

# ==========================================
# REDIS - Cache & Sessions
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# AWS - Cloud Infrastructure
# Get from: https://console.aws.amazon.com/
# ==========================================
AWS_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# ==========================================
# SENTRY - Error Tracking
# Get from: https://sentry.io/settings/
# ==========================================
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx