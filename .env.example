# FrontDesk Agents environment variables (masked placeholders)
# Copy this file to .env and fill in actual values.

# Bland.ai API key (required for outbound calls)
BLAND_API_KEY=your_bland_api_key_here

# Optional Bland.ai webhook settings for inbound calls
BLAND_WEBHOOK_URL=https://yourdomain.com/api/bland/webhook
BLAND_WEBHOOK_SECRET=your_bland_webhook_secret

# Outbound caller ID (business number)
BLAND_OUTBOUND_NUMBER=+121****4413

# Language detection period (seconds)
BLAND_LANG_DETECT_PERIOD=4

# NVIDIA NIM API key (optional – primary brain)
NIM_API_KEY=your_nim_api_key_here
# Optional override for specific NIM model(s) – comma separated if multiple
NIM_MODEL=meta/llama-3.3-70b-instruct

# Anthropic API key (fallback brain – Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional override for Claude model – comma separated list if needed
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI API key (last-resort fallback)
OPENAI_API_KEY=your_openai_api_key_here
# Optional override for OpenAI model – comma separated list if needed
OPENAI_MODEL=gpt-4o-mini

# Vercel blob token (if using Vercel storage)
BLOB_READ_WRITE_TOKEN=your_blob_token_here
