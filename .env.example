[TEMPLATE]
# FRONTDESK AGENTS - Environment Variables

# ==========================================
# COMMUNICATION DEPARTMENT
# ==========================================

# Twilio - Voice & SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Bland.ai - AI Voice Calls
BLAND_API_KEY=your_bland_api_key

# ==========================================
# OWNER & SECURITY
# ==========================================

# Owner Password (SHA-256 hash - change this!)
OWNER_PASSWORD_HASH=placeholder_hash_change_in_env
PASSWORD_SALT=your_secure_salt_here

# ==========================================
# APPLICATION
# ==========================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# DATABASE & CACHE (Optional)
# ==========================================

DATABASE_URL=postgresql://user:password@localhost:5432/frontdesk
REDIS_URL=redis://localhost:6379

# ==========================================
# AI SERVICES
# ==========================================

OPENAI_API_KEY=your_openai_api_key

# ==========================================
# EMAIL (SMTP)
# ==========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ==========================================
# ANALYTICS
# ==========================================

NEXT_PUBLIC_GA_ID=your_google_analytics_id
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# ==========================================
# FEATURE FLAGS
# ==========================================

NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_MULTI_LANGUAGE=true
NEXT_PUBLIC_VOICE_ENABLED=true
NEXT_PUBLIC_VIDEO_ENABLED=true
NEXT_PUBLIC_TWILIO_ENABLED=true
NEXT_PUBLIC_BLAND_ENABLED=true
