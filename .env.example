# =============================================================================
# FrontDesk Agents — environment variables
#
# Copy this file to `.env.local` for development, or set each var in Vercel
# (Project Settings → Environment Variables) for production. Anything left
# unset just disables the related feature (Stripe, Square, PayPal, an LLM
# provider, Bland.ai voice, etc.) — the app stays up either way.
# =============================================================================

# -----------------------------------------------------------------------------
# Owner / admin login (replaces the hardcoded default — REQUIRED for prod)
# -----------------------------------------------------------------------------
OWNER_EMAIL=you@yourdomain.com
OWNER_PASSWORD=change-me-to-something-very-long-and-random

# -----------------------------------------------------------------------------
# Storage — Vercel Blob token (production durability). Leave empty for /tmp.
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Public site URL — used to build absolute checkout success / cancel / webhook
# URLs. On Vercel this defaults to VERCEL_PROJECT_PRODUCTION_URL.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://frontdeskagents.com

# -----------------------------------------------------------------------------
# HERMES — the LLM orchestrator behind AVA.
#
# HERMES walks a (provider, model) cascade in order. The first provider to
# return a non-empty reply wins; everything else silently falls through. Order:
#   1. NVIDIA NIM  (primary brain — see NIM_MODELS below)
#   2. Anthropic Claude  (fallback)
#   3. OpenAI  (last-resort fallback)
#
# *_MODELS env vars accept a comma-separated list, walked left-to-right. If a
# *_MODELS list is empty, HERMES uses a curated default. The legacy *_MODEL
# singular form is still honored for backwards compatibility.
#
# If you set zero LLM keys, HERMES falls through to the deterministic agent
# core — the platform never goes dark.
# -----------------------------------------------------------------------------

# --- NVIDIA NIM (primary brain) ----------------------------------------------
# Sign up at https://build.nvidia.com to get a free API key. Default base URL
# is https://integrate.api.nvidia.com/v1 (OpenAI-compatible).
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# Comma-separated list. Leave empty to use the curated default cascade:
# meta/llama-3.3-70b-instruct, nvidia/llama-3.1-nemotron-70b-instruct,
# meta/llama-3.1-405b-instruct, mistralai/mixtral-8x22b-instruct-v0.1,
# qwen/qwen2.5-72b-instruct, deepseek-ai/deepseek-r1, google/gemma-2-27b-it,
# meta/llama-3.1-70b-instruct, microsoft/phi-3-medium-128k-instruct
NIM_MODELS=
NIM_MAX_TOKENS=300

# --- Anthropic Claude (fallback) ---------------------------------------------
ANTHROPIC_API_KEY=
# Comma-separated. Defaults to: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODELS=

# --- OpenAI (last-resort fallback) -------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Comma-separated. Defaults to: gpt-4o-mini, gpt-4o
OPENAI_MODELS=

# -----------------------------------------------------------------------------
# Bland.ai outbound voice — optional, lights up the admin "Call" button.
# -----------------------------------------------------------------------------
BLAND_API_KEY=

# =============================================================================
# Stripe — primary payment processor
# Dashboard: https://dashboard.stripe.com
#
# Setup:
#   1. Create a Product for each paid tier (Starter, Professional, Growth).
#   2. Under each product, create a recurring monthly Price at the right amount.
#   3. Copy the `price_xxx` ID into STRIPE_PRICE_* below.
#   4. Add a webhook endpoint pointed at  {NEXT_PUBLIC_APP_URL}/api/billing/webhook/stripe
#      Listening for: checkout.session.completed, customer.subscription.created,
#      customer.subscription.updated, customer.subscription.deleted.
#   5. Copy the signing secret (whsec_...) into STRIPE_WEBHOOK_SECRET.
# =============================================================================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_GROWTH=price_xxx

# =============================================================================
# Square — secondary processor (invoiced subscriptions)
# Dashboard: https://app.squareup.com
#
# Setup:
#   1. Square Dashboard → Items & Orders → Subscription Plans → create one plan
#      per tier (Starter $29, Professional $79, Growth $249), monthly cadence.
#   2. Each plan has a Variation ID — copy it into SQUARE_PLAN_* below.
#   3. Developer dashboard → Webhooks → add a subscription event subscription
#      pointed at  {NEXT_PUBLIC_APP_URL}/api/billing/webhook/square
#      Events: subscription.created, subscription.updated.
#   4. Copy the signature key into SQUARE_WEBHOOK_SIGNATURE_KEY.
# =============================================================================
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_PLAN_STARTER=
SQUARE_PLAN_PROFESSIONAL=
SQUARE_PLAN_GROWTH=

# =============================================================================
# PayPal — tertiary processor (hosted approval flow)
# Dashboard: https://developer.paypal.com
#
# Setup:
#   1. Create a Product (Catalog → Products → Add).
#   2. Create three Plans linked to that product — monthly $29/$79/$249.
#   3. Copy plan IDs into PAYPAL_PLAN_* below.
#   4. Webhooks → Add webhook pointed at  {NEXT_PUBLIC_APP_URL}/api/billing/webhook/paypal
#      Events: BILLING.SUBSCRIPTION.ACTIVATED, .UPDATED, .CANCELLED,
#              .SUSPENDED, .EXPIRED, .PAYMENT.FAILED.
#   5. Copy the webhook ID into PAYPAL_WEBHOOK_ID.
# =============================================================================
PAYPAL_ENVIRONMENT=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_PROFESSIONAL=
PAYPAL_PLAN_GROWTH=
